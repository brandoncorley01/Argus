# Argus local infrastructure — copy to .env and set values.
# Never commit .env or real credentials.

# PostgreSQL 16
POSTGRES_USER=argus
POSTGRES_PASSWORD=change-me-before-use
POSTGRES_DB=argus
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

# Redis 7
REDIS_PORT=6379
REDIS_HOST=127.0.0.1

# Compose project name (optional)
COMPOSE_PROJECT_NAME=argus

# Argus API (Phase 2) — derived connection URLs for local development
DATABASE_URL=postgresql+psycopg://argus:change-me-before-use@127.0.0.1:5432/argus
REDIS_URL=redis://127.0.0.1:6379/0
APP_NAME=Argus API
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
