# Controlled paper operation template — copy to .env for local paper runtime.
# Never commit the real .env. No broker credentials. Live execution stays disabled.

POSTGRES_USER=argus
POSTGRES_PASSWORD=change-me-before-use
POSTGRES_DB=argus
POSTGRES_PORT=5432
POSTGRES_HOST=127.0.0.1

REDIS_PORT=6379
REDIS_HOST=127.0.0.1
COMPOSE_PROJECT_NAME=argus

DATABASE_URL=postgresql+psycopg://argus:change-me-before-use@127.0.0.1:5432/argus
REDIS_URL=redis://127.0.0.1:6379/0
APP_NAME=Argus API
APP_ENV=paper
API_HOST=127.0.0.1
API_PORT=8000

SESSION_COOKIE_NAME=argus_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_HOURS=8
LOGIN_MAX_FAILURES=5
LOGIN_FAILURE_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15
ALLOW_ADDITIONAL_FOUNDERS=false

HEALTH_SUPERVISOR_LEASE_SECONDS=45
HEALTH_SUPERVISOR_FAILURE_THRESHOLD=3

# EOC → API
ARGUS_API_BASE_URL=http://127.0.0.1:8000

# Enforcement (documented; provider default is DB-seeded internal_paper):
# - Execution provider: internal_paper
# - Live execution: disabled / not certified
# - No broker or exchange API keys
# - No real withdrawal capability
